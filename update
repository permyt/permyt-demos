#!/usr/bin/env bash
#
# PERMYT demos — monorepo deploy/update script.
#
# Pulls the repo once, then updates ONLY the demos that need it:
#   * their code changed in the pull, OR
#   * --force was given (all demos), OR
#   * the demo has no .venv yet (first deploy).
# Unchanged demos are skipped.
#
# "Update" a demo = ensure its uv virtualenv (.venv), install prod dependencies,
# migrate, push scopes (providers only), collect static, and restart that
# demo's supervisor programs (names are read from the demo's own config/).
#
# Usage:
#   ./update                 # pull, update changed demos
#   ./update --force         # update every demo, changed or not
#   ./update bank government  # update only these demos (implies force)
#
# Each demo is a uv project (pyproject.toml + uv.lock, Python pinned by
# .python-version); prod deps install via `uv sync --frozen --no-dev`.
#
# Requires: uv, git, sudo supervisorctl.

set -uo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

FORCE=0
ONLY=()
for arg in "$@"; do
    case "$arg" in
        -f|--force) FORCE=1 ;;
        -*) echo "unknown option: $arg" >&2; exit 2 ;;
        *) ONLY+=("$arg"); FORCE=1 ;;   # naming demos updates just those
    esac
done

# --- Pull once, capture what changed -------------------------------------
BEFORE="$(git rev-parse HEAD 2>/dev/null || echo none)"
if [ ${#ONLY[@]} -eq 0 ]; then
    echo "==> git pull"
    git pull || { echo "git pull failed" >&2; exit 1; }
fi
AFTER="$(git rev-parse HEAD 2>/dev/null || echo none)"

CHANGED=""
if [ "$BEFORE" != "$AFTER" ] && [ "$BEFORE" != none ]; then
    CHANGED="$(git diff --name-only "$BEFORE" "$AFTER")"
fi

demo_has_changes() {  # $1 = demo dir
    [ -n "$CHANGED" ] && grep -q "^$1/" <<<"$CHANGED"
}

demo_selected() {     # $1 = demo dir  (only meaningful when ONLY is set)
    local d
    for d in "${ONLY[@]}"; do [ "$d" = "$1" ] && return 0; done
    return 1
}

# --- Update a single demo (in a subshell so one failure doesn't abort all) --
update_demo() {
    local dir="$1"
    (
        set -e
        cd "$dir"

        # uv-managed virtualenv at .venv, prod deps only (dev group excluded).
        # uv sync creates .venv using the demo's .python-version and installs
        # exactly what's pinned in uv.lock.
        uv sync --frozen --no-dev

        local py=".venv/bin/python"
        "$py" manage.py migrate --no-input
        # Every demo ships an update_scope command (a no-op for requesters), so
        # it is always safe to run.
        "$py" manage.py update_scope
        "$py" manage.py collectstatic --no-input

        # Restart this demo's supervisor programs, read from its own config so
        # the names stay correct regardless of the directory name.
        local targets=() name
        while IFS= read -r name; do
            [ -n "$name" ] && targets+=("$name:*")          # fcgi-program -> group
        done < <(grep -hoE '^\[fcgi-program:[^]]+\]' config/*.conf 2>/dev/null \
                 | sed -E 's/^\[fcgi-program:([^]]+)\]/\1/')
        while IFS= read -r name; do
            [ -n "$name" ] && targets+=("$name")            # program -> plain
        done < <(grep -hoE '^\[program:[^]]+\]' config/*.conf 2>/dev/null \
                 | sed -E 's/^\[program:([^]]+)\]/\1/')

        if [ ${#targets[@]} -gt 0 ]; then
            sudo supervisorctl restart "${targets[@]}"
        else
            echo "   (no supervisor programs found in $dir/config — skipped restart)"
        fi
    )
}

# --- Loop over deployable demos ------------------------------------------
updated=0 skipped=0 failed=0
for mp in */manage.py; do
    [ -e "$mp" ] || continue
    dir="${mp%/manage.py}"
    [ -d "$dir/config" ] || continue   # only demos with deploy config

    if [ ${#ONLY[@]} -gt 0 ]; then
        demo_selected "$dir" || { echo "--  skip $dir (not selected)"; skipped=$((skipped+1)); continue; }
    elif [ "$FORCE" -ne 1 ] && [ -d "$dir/.venv" ] && ! demo_has_changes "$dir"; then
        echo "--  skip $dir (no changes)"; skipped=$((skipped+1)); continue
    fi

    echo "==> updating $dir"
    if update_demo "$dir"; then
        updated=$((updated+1))
    else
        echo "!!  $dir FAILED" >&2
        failed=$((failed+1))
    fi
done

echo "==> done: $updated updated, $skipped skipped, $failed failed"
[ "$failed" -eq 0 ]
